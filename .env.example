# Copy to .env and fill in. Anything left out uses the defaults in app/config.py.

# --- Security (CHANGE THIS) ---
JWT_SECRET=replace-with-a-long-random-string

# --- LLM provider: openai | gemini | groq | mock ---
# Use "mock" to run the whole pipeline offline with no API key (plumbing/demo only).
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# --- Embeddings: sentence_transformers (local, free) | openai ---
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=BAAI/bge-m3

# --- Reranker ---
USE_RERANKER=true
RERANKER_PROVIDER=cross_encoder      # cross_encoder | cohere | none
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
COHERE_API_KEY=

# --- Vector store: chroma (local) | qdrant (prod, stub) ---
VECTOR_STORE=chroma
CHROMA_DIR=./chroma_db

# --- Retrieval defaults (also overridable per-experiment in evaluation) ---
RETRIEVAL_MODE=hybrid                # hybrid (BM25 + dense, RRF) | dense
RETRIEVAL_LANG=bn                    # bn (native) | en (English-pivot)
TOP_K=20
RERANK_K=5
RRF_K=60                             # Reciprocal Rank Fusion constant
CHUNKER=recursive                    # fixed | recursive | sentence_bn
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# --- Uploads ---
MAX_UPLOAD_MB=10                     # reject uploaded files larger than this

# --- DB ---
DATABASE_URL=sqlite:///./banglarag.db
